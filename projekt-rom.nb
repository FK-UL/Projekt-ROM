Cell["\<\
Zdi se, da so vse te besede dosegle vrhunec okoli leta 1990 (z izjemo besede \
algoritem), medtem ko sem pri\[CHacek]akoval, da bodo te besede dosegle \
vrhunec okoli leta 2000.
\
\>", "Text",
 CellChangeTimes->{{3.992101738092971*^9, 3.9921017398059273`*^9}, {
  3.9921019145845823`*^9, 3.9921019177323313`*^9}, {3.992101981441042*^9, 
  3.992101995341975*^9}},ExpressionUUID->"37f36316-da17-49af-a80f-\
5eba57ef5344"]
}, Open  ]],

